<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="~{layout}">
<head>
    <title layout:fragment="title">客户看板</title>
</head>
<body>
<th:block layout:fragment="content">

<div class="card">
    <h2>📊 客户管理看板</h2>
    <div class="text-muted mb-2">数据来源：<code>企业/客户管理/客户数据.json</code> | 最后更新：<span th:text="${last_updated}">未知</span></div>
</div>

<div class="card">
    <h2>总览统计</h2>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;">
        <div class="status-item"><div class="label">客户总数</div><div class="value" th:text="${total}">0</div></div>
        <div class="status-item"><div class="label">活跃客户</div><div class="value" style="color:#2b8a3e;" th:text="${active_count}">0</div></div>
        <div class="status-item"><div class="label">线索客户</div><div class="value" style="color:#1971c2;" th:text="${lead_count}">0</div></div>
        <div class="status-item"><div class="label">年度签约</div><div class="value" style="color:#e8590c;" th:text="${@utils.wan(total_contract)}">0</div></div>
    </div>
    <table class="log-table">
        <thead><tr><th>指标</th><th>数值</th></tr></thead>
        <tbody>
            <tr><td>客户总数</td><td th:text="${total}">0</td></tr>
            <tr><td>活跃客户</td><td th:text="${active_count}">0</td></tr>
            <tr><td>线索客户</td><td th:text="${lead_count}">0</td></tr>
            <tr><td>已流失客户</td><td th:text="${churned_count}">0</td></tr>
            <tr><td>年度目标</td><td th:text="${@utils.wan(target)}">0</td></tr>
            <tr><td>签约金额（2026）</td><td th:text="${@utils.wan(total_contract)}">0</td></tr>
            <tr><td>实际收款（2026）</td><td th:text="${@utils.wan(total_paid)}">0</td></tr>
            <tr><td>完成率</td>
                <td th:if="${target > 0}">
                    <span th:text="${@utils.fmtOne(total_contract / target * 100)} + '%（金额） / ' + ${@utils.fmtOne(total_paid / target * 100)} + '%（流水）'">完成率</span>
                </td>
                <td th:unless="${target > 0}">—</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="card">
    <h2>客户漏斗</h2>
    <div style="display:flex;flex-direction:column;gap:2px;">
        <th:block th:each="stageEntry : ${pipeline_stages}">
            <th:block th:with="stageName=${stageEntry.key}, stageData=${stageEntry.value}">
                <th:block th:if="${@utils.toInt(stageData.count) > 0}">
                    <th:block th:with="barColor=${stageData.color != null ? stageData.color : '#868e96'}, barWidth=${max_funnel_count > 0 ? @utils.toInt(stageData.count) * 100 / @utils.toInt(max_funnel_count) : 0}">
                <div style="display:flex;align-items:center;gap:10px;padding:6px 0;">
                    <div style="width:100px;font-size:13px;color:#5c5f66;font-weight:500;text-align:right;" th:text="${stageName}">阶段</div>
                    <div style="flex:1;display:flex;align-items:center;gap:8px;">
                        <div th:style="'height:24px;width:' + ${barWidth} + '%;min-width:4px;background:' + ${barColor} + ';border-radius:4px;opacity:0.85;transition:width .2s;'"></div>
                        <span style="font-size:15px;font-weight:700;color:#1a1b1e;min-width:20px;" th:text="${@utils.toInt(stageData.count)}">0</span>
                    </div>
                    <div style="font-size:12px;color:#909296;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        <th:block th:if="${stageData.customers != null and #lists.size(stageData.customers) > 0 and stageData.customers[0].notes != null}">
                            <span th:text="${@utils.limit(stageData.customers[0].notes, 30)}">备注</span>
                        </th:block>
                    </div>
                </div>
                    </th:block>
                </th:block>
            </th:block>
        </th:block>
    </div>
</div>

<div class="card">
    <h2>线索漏斗</h2>
    <div style="display:flex;flex-direction:column;gap:2px;">
        <th:block th:each="funnelEntry : ${lead_funnel}">
            <th:block th:with="statusName=${funnelEntry.key}, statusData=${funnelEntry.value}">
                <th:block th:if="${@utils.toInt(statusData.count) > 0}">
                    <th:block th:with="barColor=${statusData.color != null ? statusData.color : '#868e96'}, barWidth=${max_lead_funnel > 0 ? @utils.toInt(statusData.count) * 100 / @utils.toInt(max_lead_funnel) : 0}">
                <div style="display:flex;align-items:center;gap:10px;padding:6px 0;">
                    <div style="width:100px;font-size:13px;color:#5c5f66;font-weight:500;text-align:right;" th:text="${statusName}">状态</div>
                    <div style="flex:1;display:flex;align-items:center;gap:8px;">
                        <div th:style="'height:24px;width:' + ${barWidth} + '%;min-width:4px;background:' + ${barColor} + ';border-radius:4px;opacity:0.85;transition:width .2s;'"></div>
                        <span style="font-size:15px;font-weight:700;color:#1a1b1e;min-width:20px;" th:text="${@utils.toInt(statusData.count)}">0</span>
                    </div>
                    <div style="font-size:12px;color:#909296;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        <th:block th:if="${statusData.leads != null and #lists.size(statusData.leads) > 0 and statusData.leads[0].notes != null}">
                            <span th:text="${@utils.limit(statusData.leads[0].notes, 30)}">备注</span>
                        </th:block>
                    </div>
                </div>
                    </th:block>
                </th:block>
            </th:block>
        </th:block>
    </div>
</div>

<div class="card">
    <h2>2026 年度营收</h2>
    <table class="log-table">
        <thead><tr><th>#</th><th>客户</th><th>合同</th><th>金额</th><th>已收款</th><th>未收款</th></tr></thead>
        <tbody>
            <tr th:each="c, iterStat : ${revenue_customers}">
                <td th:text="${iterStat.count}">1</td>
                <td th:text="${c.name}">客户</td>
                <td th:text="${c.get('product') != null ? c.get('product') : '—'}">—</td>
                <td th:text="${@utils.wan(@utils.toDouble(c.get('contractAmount')))}">0</td>
                <td th:text="${@utils.wan(@utils.toDouble(c.get('paidAmount')))}">0</td>
                <td th:text="${@utils.wan(@utils.toDouble(c.get('contractAmount')) - @utils.toDouble(c.get('paidAmount')))}">0</td>
            </tr>
            <tr>
                <td colspan="2"><strong>合计</strong></td>
                <td></td>
                <td><strong th:text="${@utils.wan(total_contract)}">0</strong></td>
                <td><strong th:text="${@utils.wan(total_paid)}">0</strong></td>
                <td><strong th:text="${@utils.wan(total_contract - total_paid)}">0</strong></td>
            </tr>
        </tbody>
    </table>
    <div class="text-muted" style="margin-top:8px;">
        年度目标 <span th:text="${@utils.wan(target)}">0</span>，完成
        <span th:text="${@utils.fmtOne(total_contract/target*100)} + '%（金额）/ ' + ${@utils.fmtOne(total_paid/target*100)} + '%（流水）'">完成率</span>
    </div>
</div>

<div class="card">
    <h2 style="display:flex;justify-content:space-between;align-items:center;">服务中 <a href="/customers/all" style="font-size:13px;font-weight:400;color:#7c5cfc;text-decoration:none;">查看所有 →</a></h2>
    <table class="log-table">
        <thead><tr><th style="width:50px;">ID</th><th>客户</th><th>公司</th><th>地区</th><th>阶段</th><th>产品</th><th>联系人</th><th>合同/收款</th><th>备注</th></tr></thead>
        <tbody>
            <th:block th:each="c : ${customers}">
                <th:block th:if="${c.stage == '已签约-待首款' or c.stage == '进行中' or c.stage == '售后中'}">
                <tr>
                    <td><small th:text="${c.id}">ID</small></td>
                    <td><strong th:text="${c.name}">客户</strong></td>
                    <td th:text="${c.get('company') != null ? c.get('company') : '—'}">—</td>
                    <td th:text="${c.get('region') != null ? c.get('region') : '—'}">—</td>
                    <td th:text="${c.stage}">阶段</td>
                    <td th:text="${c.get('product') != null ? c.get('product') : '—'}">—</td>
                    <td>
                        <th:block th:if="${c.contacts != null and #lists.size(c.contacts) > 0}" th:with="contact=${c.contacts[0]}">
                            <span th:text="${contact.get('name') != null ? contact.get('name') : ''}"></span>
                            <br><small th:if="${contact.get('phone') != null}" th:text="${contact.get('phone')}"></small>
                            <br><small th:if="${contact.get('email') != null}" th:text="${contact.get('email')}"></small>
                        </th:block>
                    </td>
                    <td>
                        <th:block th:if="${@utils.toDouble(c.get('contractAmount')) > 0}">
                            <span th:text="${@utils.wan(@utils.toDouble(c.get('contractAmount')))} + '/' + ${@utils.wan(@utils.toDouble(c.get('paidAmount')))}">合同/收款</span>
                        </th:block>
                        <th:block th:unless="${@utils.toDouble(c.get('contractAmount')) > 0}">—</th:block>
                    </td>
                    <td th:text="${c.notes != null ? @utils.limit(c.notes, 30) : ''}">备注</td>
                </tr>
                </th:block>
            </th:block>
            <tr th:if="${#lists.size(customers) == 0}">
                <td colspan="6" style="text-align:center;color:#909296;">暂无服务中的客户</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="card">
    <h2 style="display:flex;justify-content:space-between;align-items:center;">线索池 <a href="/leads/all" style="font-size:13px;font-weight:400;color:#7c5cfc;text-decoration:none;">查看所有 →</a></h2>
    <table class="log-table">
        <thead><tr><th style="width:50px;">ID</th><th style="width:105px;">最后跟进</th><th>客户</th><th>公司</th><th>地区</th><th>来源</th><th style="width:80px;">状态</th><th>联系人</th><th>跟进内容</th><th>备注</th></tr></thead>
        <tbody>
            <th:block th:each="l : ${leads}">
                <th:block th:if="${l.status == '跟进中' or l.status == '待跟进'}">
                    <th:block th:with="activities=${@utils.toList(l.get('activities'))}, lastAct=${#lists.size(activities) > 0 ? activities[#lists.size(activities)-1] : null}">
                <tr>
                    <td><small th:text="${l.id}">ID</small></td>
                    <td th:text="${lastAct != null ? @utils.limit(lastAct.get('date') != null ? lastAct.get('date') : '', 10) : @utils.limit(l.get('createdAt') != null ? l.get('createdAt') : '', 10)}">日期</td>
                    <td><strong th:text="${l.name}">客户</strong></td>
                    <td th:text="${l.get('company') != null ? l.get('company') : '—'}">—</td>
                    <td th:text="${l.get('region') != null ? l.get('region') : '—'}">—</td>
                    <td th:text="${l.source}">来源</td>
                    <td th:text="${l.status}">状态</td>
                    <td>
                        <th:block th:if="${l.contacts != null and #lists.size(l.contacts) > 0}" th:with="contact=${l.contacts[0]}">
                            <span th:text="${contact.get('name') != null ? contact.get('name') : ''}"></span>
                            <span th:if="${contact.get('phone') != null}" th:text="' ' + ${contact.get('phone')}"></span>
                            <span th:if="${contact.get('wechat') != null}" th:text="' ' + ${contact.get('wechat')}"></span>
                        </th:block>
                    </td>
                    <td th:text="${lastAct != null ? @utils.limit(lastAct.get('content') != null ? lastAct.get('content') : '', 40) : @utils.limit(l.get('notes') != null ? l.get('notes') : '', 30)}">内容</td>
                    <td th:text="${l.notes != null ? @utils.limit(l.notes, 30) : '—'}">备注</td>
                </tr>
                    </th:block>
                </th:block>
            </th:block>
        </tbody>
    </table>
</div>

<div class="card">
    <h2>待办</h2>
    <table class="log-table">
        <thead><tr><th>优先级</th><th>客户</th><th>事项</th></tr></thead>
        <tbody>
            <tr th:each="c, iterStat : ${todos}" th:if="${iterStat.index < 8}">
                <th:block th:with="urgency=${c.nextFollowUp != null and #strings.contains(c.nextFollowUp, '06') ? '🔴' : (c.nextFollowUp != null ? '🟡' : '🟢')}">
                <td>
                    <span th:style="'color:' + (${urgency} == '🔴' ? '#e03131' : (${urgency} == '🟡' ? '#e8590c' : '#2b8a3e')) + ';'" th:text="${urgency}">🔴</span>
                </td>
                </th:block>
                <td th:text="${c.name}">客户</td>
                <td th:text="${c.notes != null ? @utils.limit(c.notes, 50) : ''}">事项</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="card">
    <h2>最近活动</h2>
    <table class="log-table">
        <thead><tr><th style="width:105px;">日期</th><th style="width:120px;">客户</th><th style="width:80px;">类型</th><th>内容</th></tr></thead>
        <tbody>
            <tr th:each="act : ${recent_activities}">
                <td th:text="${act.date}">日期</td>
                <td th:text="${act.customer}">客户</td>
                <td th:text="${act.type}">类型</td>
                <td th:text="${@utils.limit(act.content, 60)}">内容</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="card" style="text-align:center;">
    <button class="btn btn-primary" onclick="showAddRecord()">+ 添加跟进记录</button>
</div>

<div class="modal-overlay" id="addRecordModal">
    <div class="modal">
        <h3>添加跟进记录</h3>
        <form id="addRecordForm" onsubmit="return submitRecord(event)">
            <div class="form-row">
                <div class="form-group">
                    <label>客户/线索 *</label>
                    <select name="customerId" required id="recordCustomerId" onchange="updateCustomerName()">
                        <option value="">— 选择客户或线索 —</option>
                        <optgroup label="已合作客户">
                            <option th:each="c : ${customers}" th:value="${c.id}" th:attr="data-name=${c.name}" th:text="${c.id + ' ' + c.name}">客户</option>
                        </optgroup>
                        <optgroup label="线索">
                            <option th:each="l : ${leads}" th:value="${l.id}" th:attr="data-name=${l.name}" th:text="${l.id + ' ' + l.name}">线索</option>
                        </optgroup>
                    </select>
                    <input type="hidden" name="customerName" id="recordCustomerName">
                </div>
                <div class="form-group">
                    <label>类型</label>
                    <select name="actType">
                        <option value="跟进">跟进</option>
                        <option value="咨询">咨询</option>
                        <option value="演示">演示</option>
                        <option value="测试">测试</option>
                        <option value="签约">签约</option>
                        <option value="收款">收款</option>
                        <option value="已放弃">已放弃</option>
                        <option value="其他">其他</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>日期</label>
                    <input type="date" name="date" id="recordDate">
                </div>
                <div class="form-group">
                    <label>下次跟进</label>
                    <input type="date" name="nextFollowUp" id="recordNextFollowUp">
                </div>
            </div>
            <div class="form-group">
                <label>跟进内容 *</label>
                <textarea name="content" required rows="3" placeholder="详细描述跟进内容"></textarea>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addRecordModal')">取消</button>
                <button type="submit" class="btn btn-primary">保存</button>
            </div>
        </form>
    </div>
</div>

<script>
function showAddRecord() {
    document.getElementById('addRecordModal').classList.add('active');
    document.getElementById('recordDate').value = new Date().toISOString().slice(0,10);
}
function closeModal(id) { document.getElementById(id).classList.remove('active'); }
function updateCustomerName() {
    const sel = document.getElementById('recordCustomerId');
    const opt = sel.options[sel.selectedIndex];
    document.getElementById('recordCustomerName').value = opt ? opt.getAttribute('data-name') || '' : '';
}
function submitRecord(e) {
    e.preventDefault();
    const form = document.getElementById('addRecordForm');
    const data = new FormData(form);
    fetch('/api/records/add', { method: 'POST', body: data })
    .then(r => r.json())
    .then(res => {
        if (res.ok) { toast('跟进记录添加成功'); closeModal('addRecordModal'); form.reset(); location.reload(); }
        else { toast(res.error || '添加失败', 'error'); }
    })
    .catch(() => toast('网络错误', 'error'));
    return false;
}
document.getElementById('addRecordModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal('addRecordModal');
});
</script>

</th:block>
</body>
</html>