<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="~{layout}">
<head>
    <title layout:fragment="title">运营看板</title>
</head>
<body>
<th:block layout:fragment="content">

<div class="card">
    <h2>📊 自媒体运营看板</h2>
    <div class="text-muted mb-2">数据来源：<code>自媒体/运营数据.json</code> | 最后更新：<span th:text="${last_updated}">未知</span></div>
</div>

<div class="card">
    <h2>📈 每日数据统计</h2>
    <div class="text-muted mb-2">账号级每日汇总数据，来源：<code>运营数据.json → dailyStats</code></div>
    <th:block th:each="statsEntry : ${daily_stats}">
        <th:block th:with="account_name=${statsEntry.key}, stats=${statsEntry.value}">
            <th:block th:if="${#lists.size(stats) > 0}">
            <h3 style="font-size:14px;margin:12px 0 6px;" th:text="${account_name}">账号名</h3>
            <table class="log-table">
                <thead><tr><th>日期</th><th>粉丝</th><th>阅读量</th><th>文章数</th><th>推荐</th><th>搜一搜</th><th>消息</th><th>朋友圈</th></tr></thead>
                <tbody>
                    <tr th:each="day : ${stats}">
                        <td th:text="${day.date}">日期</td>
                        <td th:text="${day.fans != null ? day.fans : '—'}">—</td>
                        <td th:text="${day.reads}">0</td>
                        <td th:text="${day.readArticles}">0</td>
                        <td th:text="${@utils.pct(day.sourceRecommend != null ? day.sourceRecommend : 0, day.reads != null ? day.reads : 0)}">0%</td>
                        <td th:text="${@utils.pct(day.sourceSearch != null ? day.sourceSearch : 0, day.reads != null ? day.reads : 0)}">0%</td>
                        <td th:text="${@utils.pct(day.sourceMessage != null ? day.sourceMessage : 0, day.reads != null ? day.reads : 0)}">0%</td>
                        <td th:text="${@utils.pct(day.sourceMoments != null ? day.sourceMoments : 0, day.reads != null ? day.reads : 0)}">0%</td>
                    </tr>
                </tbody>
            </table>
            </th:block>
        </th:block>
    </th:block>
</div>

<div class="card">
    <h2>账号总览</h2>
    <table class="log-table">
        <thead>
            <tr><th>账号</th><th>平台</th><th>账号名</th><th>粉丝</th><th>备注</th></tr>
        </thead>
        <tbody>
            <th:block th:each="accEntry : ${accounts}">
                <th:block th:with="accName=${accEntry.key}, platforms=${accEntry.value}, rowspan=${#maps.size(platforms)}">
                <th:block th:each="platEntry, platStat : ${platforms}" th:with="platKey=${platEntry.key}, info=${platEntry.value}">
                <tr>
                    <th:block th:if="${platStat.first}">
                    <td th:rowspan="${rowspan}"><strong th:text="${accName}">账号名</strong></td>
                    </th:block>
                    <td th:text="${@utils.platformName(platKey)}">平台</td>
                    <td th:text="${info.name}">—</td>
                    <td th:text="${info.fans != null ? info.fans : '—'}">—</td>
                    <td>
                        <th:block th:if="${info.totalViews != null}">
                            <span th:text="'总访问' + info.totalViews + '，原创' + info.totalArticles + '篇'">统计</span>
                        </th:block>
                        <th:block th:if="${info.totalViews == null and info.fansUpdated != null}">
                            <span th:text="'更新于 ' + info.fansUpdated">更新</span>
                        </th:block>
                        <th:block th:if="${info.totalViews == null and info.fansUpdated == null}">—</th:block>
                    </td>
                </tr>
                </th:block>
                </th:block>
            </th:block>
        </tbody>
    </table>
</div>

<th:block th:each="artEntry : ${articles}">
    <th:block th:with="accName=${artEntry.key}, articleList=${artEntry.value}">
    <div class="card">
        <h2 th:text="${accName}">账号名</h2>
        <table class="log-table" style="margin-top:8px;">
            <thead><tr><th style="width:32px">ID</th><th style="width:125px">日期</th><th style="text-align:left">文章</th><th style="width:48px">阅读</th><th style="width:36px">👍</th><th style="width:36px">🔁</th></tr></thead>
            <tbody>
                <tr th:each="article : ${articleList}">
                    <td th:text="${article.id}">ID</td>
                    <td th:text="${article.publishDate}">日期</td>
                    <td style="text-align:left">
                        <span th:text="${article.topic}">文章</span>
                        <th:block th:if="${article.fansGained != null}">
                            <br><small class="text-muted" th:text="'增粉 ' + ${article.fansGained}"></small>
                        </th:block>
                    </td>
                    <td th:text="${article.data != null and article.data.get('wechat') != null ? article.data.get('wechat').reads : '—'}">—</td>
                    <td th:text="${article.data != null and article.data.get('wechat') != null ? article.data.get('wechat').likes : '—'}">—</td>
                    <td th:text="${article.data != null and article.data.get('wechat') != null ? article.data.get('wechat').shares : '—'}">—</td>
                </tr>
            </tbody>
        </table>
        <th:block th:each="article : ${articleList}">
            <th:block th:if="${article.notes != null and !article.notes.isEmpty()}">
            <div class="text-muted" style="font-size:12px;margin-top:4px;">备注：<span th:text="${article.notes}"></span></div>
            </th:block>
        </th:block>
    </div>
    </th:block>
</th:block>

<div class="card">
    <h2>发布节奏</h2>
    <table class="log-table">
        <thead><tr><th>账号</th><th>首发</th><th>次发</th><th>最后</th></tr></thead>
        <tbody>
            <tr><td>码农老齐</td><td>周二18:00-19:00 微信</td><td>周三09:00-10:00 CSDN</td><td>周四20:00-22:00 知乎</td></tr>
            <tr><td>启航电商ERP</td><td>周四20:00 微信（电商干货、产品动态）</td><td>—</td><td>—</td></tr>
        </tbody>
    </table>
</div>

<th:block th:if="${analysis != null}">
<div class="card">
    <h2>📈 文章综合分析 & 建议</h2>

    <th:block th:if="${analysis.topArticles != null and #lists.size(analysis.topArticles) > 0}">
    <h3 style="font-size:14px;margin:12px 0 8px;">🏆 最佳表现文章 TOP</h3>
    <table class="log-table">
        <thead><tr><th>#</th><th>账号</th><th>文章</th><th>平台</th><th>阅读</th><th>增粉</th></tr></thead>
        <tbody>
            <tr th:each="a, iterStat : ${analysis.topArticles}">
                <td th:text="${iterStat.count}">1</td>
                <td th:text="${a.account}">账号</td>
                <td th:text="${a.topic}">文章</td>
                <td th:text="${@utils.platformName(a.platform)}">平台</td>
                <td><strong th:text="${a.reads}">0</strong></td>
                <td th:text="${a.fansGained != null ? a.fansGained : '—'}">—</td>
            </tr>
        </tbody>
    </table>
    </th:block>

    <th:block th:if="${analysis.findings != null and #lists.size(analysis.findings) > 0}">
    <h3 style="font-size:14px;margin:12px 0 8px;">🔬 关键发现</h3>
    <th:block th:each="f : ${analysis.findings}">
    <div style="background:#f8f9fa;border-radius:8px;padding:12px;margin-bottom:8px;">
        <div style="font-weight:600;font-size:13px;margin-bottom:4px;" th:text="${f.icon + ' ' + f.title}">标题</div>
        <div style="font-size:12px;color:#5c5f66;margin-bottom:4px;" th:text="${f.detail}">详情</div>
        <div style="font-size:12px;color:#2b8a3e;" th:text="'→ ' + ${f.action}">动作</div>
    </div>
    </th:block>
    </th:block>

    <th:block th:if="${analysis.platformTips != null and #lists.size(analysis.platformTips) > 0}">
    <h3 style="font-size:14px;margin:12px 0 8px;">🎯 平台优化建议</h3>
    <table class="log-table">
        <thead><tr><th>平台</th><th>问题</th><th>改进动作</th></tr></thead>
        <tbody>
            <tr th:each="t : ${analysis.platformTips}">
                <td><strong th:text="${t.platform}">平台</strong></td>
                <td th:text="${t.problem}">问题</td>
                <td style="color:#2b8a3e;" th:text="'→ ' + ${t.action}">改进</td>
            </tr>
        </tbody>
    </table>
    </th:block>

    <th:block th:if="${analysis.suggestionPriority != null and #lists.size(analysis.suggestionPriority) > 0}">
    <h3 style="font-size:14px;margin:12px 0 8px;">📝 下一篇文章建议</h3>
    <table class="log-table">
        <thead><tr><th>优先级</th><th>建议选题</th><th>理由</th></tr></thead>
        <tbody>
            <tr th:each="s : ${analysis.suggestionPriority}">
                <td th:text="${s.priority}">优先级</td>
                <td th:text="${s.topic}">选题</td>
                <td style="font-size:12px;color:#5c5f66;" th:text="${s.reason}">理由</td>
            </tr>
        </tbody>
    </table>
    </th:block>

    <th:block th:if="${analysis.writingTemplate != null}">
    <h3 style="font-size:14px;margin:12px 0 8px;">✍️ 数据驱动写作模板</h3>
    <div style="background:#f0edff;border-radius:8px;padding:12px;margin-bottom:6px;">
        <div style="font-size:13px;"><strong>标题公式：</strong><span th:text="${analysis.writingTemplate.formula}"></span></div>
    </div>
    <div th:if="${analysis.writingTemplate.goodExamples != null}" style="background:#d3f9d8;border-radius:8px;padding:8px 12px;margin-bottom:4px;font-size:12px;">
        ✅ 好的：<span th:text="${#strings.listJoin(analysis.writingTemplate.goodExamples, '、')}"></span>
    </div>
    <div th:if="${analysis.writingTemplate.badExamples != null}" style="background:#ffe0e0;border-radius:8px;padding:8px 12px;margin-bottom:4px;font-size:12px;">
        ❌ 避免：<span th:text="${#strings.listJoin(analysis.writingTemplate.badExamples, '、')}"></span>
    </div>
    <div style="font-size:12px;color:#5c5f66;margin-top:6px;">
        <strong>内容优先级：</strong><span th:text="${analysis.writingTemplate.contentPipeline}"></span>
    </div>
    </th:block>
</div>
</th:block>

</th:block>
</body>
</html>